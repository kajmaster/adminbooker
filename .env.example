# Kopieer dit naar .env en vul in.

# ---------- Toegang (optioneel) ----------
# Laat PASSWORD leeg voor lokale ontwikkeling (geen login vereist).
# In productie: genereer een hash met:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('hetwachtwoord'))"
# SECRET_KEY is verplicht als login aan staat (anders vervallen sessies bij herstart).
USERNAME=admin
PASSWORD_HASH=
SECRET_KEY=vervang_dit_met_een_lange_willekeurige_string

# ---------- Boekhoudpakket ----------
# Actieve provider: 'rompslomp' (default) of 'moneybird'
ACCOUNTING_PROVIDER=rompslomp

# Moneybird
MONEYBIRD_API_KEY=jouw_api_key_hier
MONEYBIRD_ADMINISTRATION_ID=jouw_administratie_id_hier

# Rompslomp (beta - voor bouw-strategie)
# Maak API-token aan in Rompslomp via Instellingen > API
# Company-id staat in de URL na inloggen: app.rompslomp.nl/{company_id}/...
ROMPSLOMP_API_TOKEN=
ROMPSLOMP_COMPANY_ID=

# Exact Online (geparkeerd - skeleton, OAuth-flow niet uitgewerkt)
EXACT_CLIENT_ID=
EXACT_CLIENT_SECRET=
EXACT_REDIRECT_URI=http://localhost:5000/oauth/exact/callback
EXACT_DIVISION=
EXACT_REFRESH_TOKEN=

# LLM-classificatie (slimme grootboek-keuze). Vul ÉÉN van beide in.
# Zonder sleutel valt AdminBooker terug op de trefwoord-regels.
#   Anthropic (Claude Haiku 4.5):  console.anthropic.com -> API keys
#   OpenAI   (GPT-4o-mini):        platform.openai.com  -> API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optioneel: overschrijf het model (default Haiku 4.5 of gpt-4o-mini)
LLM_MODEL=

# E-mail-escalatie: stuur de eigenaar een mail als AdminBooker over een boeking
# twijfelt. Laat leeg = uit (geen mails). Gmail: maak een 'app-wachtwoord' aan.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
